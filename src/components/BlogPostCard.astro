---
import type { MediaValue } from "emdash";
import { Image } from "emdash/ui";

interface Props {
	href: string;
	category: string;
	title: string;
	featuredImage?: MediaValue;
	readMore: string;
}

const { href, category, title, featuredImage, readMore } = Astro.props;
---

<article class="blog-card">
	<a href={href}>
		{
			featuredImage ? (
				<div class="blog-card-image-wrap">
					<Image image={featuredImage} class="blog-card-image" />
				</div>
			) : (
				<div class="blog-card-image-wrap blog-card-image-fallback" aria-hidden="true" />
			)
		}
	</a>
	<div class="blog-card-body">
		<p class="blog-card-category">{category}</p>
		<h2 class="blog-card-title">
			<a href={href}>{title}</a>
		</h2>
		<a class="blog-card-link" href={href}>{readMore} →</a>
	</div>
</article>

<style>
	.blog-card-image-wrap {
		aspect-ratio: 16 / 10;
		overflow: hidden;
	}

	.blog-card-image-wrap :global(.blog-card-image),
	.blog-card-image-wrap :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.blog-card-image-fallback {
		background: var(--color-border-subtle);
	}
</style>
