---
import Aprendiz from "../layouts/Aprendiz.astro";
import FaqList from "../components/FaqList.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import { getLocaleFromAstro, getMessages } from "../i18n";

const locale = getLocaleFromAstro(Astro.currentLocale, Astro.url.hostname);
const m = getMessages(locale);
const h = m.home;
---

<Aprendiz title={m.meta.siteTitle} description={m.meta.siteDescription}>
	<section class="hero">
		<div class="container hero-grid">
			<div>
				<h1 class="heading-1">{h.heroTitle}</h1>
				<p class="hero-lead">{h.heroSubtitle}</p>
				<a href="#learning-map" class="hero-video-link">
					<img src="/images/aprendiz/icon-play.svg" alt="" width="24" height="24" />
					{h.heroCta}
				</a>
			</div>
			<div>
				<img src="/images/aprendiz/hero-mockup.png" alt="" width="800" height="600" loading="eager" />
			</div>
		</div>
	</section>

	<section class="section section-alt">
		<div class="container">
			<div class="features-header text-center">
				<h2 class="heading-2">{h.featuresTitle}</h2>
				<p class="muted">{h.featuresSubtitle}</p>
			</div>
			<div class="grid-3 features-grid">
				<div class="feature-card">
					<img class="feature-icon" src="/images/aprendiz/icon-monitoring.svg" alt="" />
					<h3 class="heading-4">{h.featureMonitoringTitle}</h3>
					<p class="muted">{h.featureMonitoringText}</p>
					<img class="feature-visual" src="/images/aprendiz/feature-radar.gif" alt="" loading="lazy" />
				</div>
				<div class="feature-card">
					<img class="feature-icon" src="/images/aprendiz/icon-adaptive.svg" alt="" />
					<h3 class="heading-4">{h.featureAdaptiveTitle}</h3>
					<p class="muted">{h.featureAdaptiveText}</p>
					<img class="feature-visual" src="/images/aprendiz/feature-content.png" alt="" loading="lazy" />
				</div>
				<div class="feature-card">
					<img class="feature-icon" src="/images/aprendiz/icon-personalized.svg" alt="" />
					<h3 class="heading-4">{h.featurePersonalTitle}</h3>
					<p class="muted">{h.featurePersonalText}</p>
					<img
						class="feature-visual"
						src="/images/aprendiz/feature-learning-map.gif"
						alt="Imagen de opciones disponibles de chat."
						loading="lazy"
					/>
				</div>
			</div>
		</div>
	</section>

	<section id="learning-map" class="section">
		<div class="container">
			<div class="grid-2" style="align-items: center;">
				<div>
					<h2 class="heading-2">{h.learningMapTitle}</h2>
					<p class="muted">{h.learningMapText}</p>
				</div>
				<div class="video-embed">
					<iframe
						src="https://www.youtube.com/embed/JFkboUzRT8Q?modestbranding=1&rel=0"
						title="aprendiz demo"
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
						allowfullscreen
						loading="lazy"></iframe>
				</div>
			</div>
		</div>
	</section>

	<section class="section section-alt">
		<div class="container">
			<h2 class="heading-2 text-center">{h.testimonialsTitle}</h2>
			<div class="grid-2" style="margin-top: 2rem;">
				<TestimonialCard
					quote={h.testimonial1Quote}
					name={h.testimonial1Name}
					role={h.testimonial1Role}
				/>
				<TestimonialCard
					quote={h.testimonial2Quote}
					name={h.testimonial2Name}
					role={h.testimonial2Role}
				/>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container text-center">
			<h2 class="heading-2">{h.lmsTitle}</h2>
			<p class="muted" style="max-width: 640px; margin-inline: auto;">{h.lmsIntro}</p>
			<div class="grid-3" style="margin-top: 2rem;">
				<div class="lms-card">
					<img src="/images/aprendiz/lms-canvas.svg" alt="Canvas LMS" />
					<p class="muted">{h.lmsCanvas}</p>
				</div>
				<div class="lms-card">
					<img src="/images/aprendiz/lms-moodle.svg" alt="Moodle LMS" />
					<p class="muted">{h.lmsMoodle}</p>
				</div>
				<div class="lms-card">
					<img src="/images/aprendiz/lms-blackboard.svg" alt="Blackboard LMS" />
					<p class="muted">{h.lmsBlackboard}</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section section-alt">
		<div class="container">
			<h2 class="heading-2 text-center">{h.faqTitle}</h2>
			<p class="muted text-center">{h.faqIntro}</p>
			<div style="margin-top: 2rem;">
				<FaqList items={h.faqItems} columns={2} />
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container cta-band">
			<div>
				<h2 class="heading-2">{h.ctaTitle}</h2>
				<p class="muted">{h.ctaText}</p>
				<a href={m.paths.contact} class="btn" style="margin-top: 1rem;">{h.ctaButton}</a>
			</div>
			<img src="/images/aprendiz/cta-pilot.png" alt="" loading="lazy" />
		</div>
	</section>
</Aprendiz>
