---
import Aprendiz from "../layouts/Aprendiz.astro";
import { getLocaleFromAstro } from "../i18n";

const locale = getLocaleFromAstro(Astro.currentLocale, Astro.url.hostname);
---

<Aprendiz title="404">
	<section class="section text-center">
		<div class="container">
			<h1 class="heading-1">404</h1>
			<p class="muted">
				{locale === "es" ? "No encontramos esta página." : "We couldn't find this page."}
			</p>
			<a href="/" class="btn" style="margin-top: 1.5rem;">
				{locale === "es" ? "Volver al inicio" : "Back to home"}
			</a>
		</div>
	</section>
</Aprendiz>
