		"posts": [
			{
				"id": "post-desafio-es",
				"slug": "el-desafio-de-ensenar-con-evidencia",
				"status": "published",
				"locale": "es",
				"data": {
					"title": "El desafío de enseñar con evidencia",
					"excerpt": "El aprendizaje también se puede leer. El nuevo rol docente exige no sólo saber enseñar, sino también interpretar lo que los datos nos dicen sobre cómo se aprende.",
					"featured_image": {
						"$media": {
							"url": "https://cdn.prod.website-files.com/687f946a33c5b5ae33cf179d/688383c8f2a197187d77da8f_ensen%CC%83anzapersonalizada.png",
							"alt": "El desafío de enseñar con evidencia",
							"filename": "blog-post-1.png"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "En el mundo actual, la información ya no es un lujo: es una herramienta estratégica. La educación necesita evidencia, lectura crítica y profesionales capaces de analizar el aprendizaje como un proceso visible y medible."
								}
							]
						},
						{
							"_type": "block",
							"style": "h2",
							"children": [{ "_type": "span", "text": "¿Qué es Learning Analytics?" }]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Learning Analytics es el proceso de recopilar, analizar e interpretar datos generados por los estudiantes con el objetivo de comprender y optimizar el aprendizaje. La analítica del aprendizaje no reemplaza al educador: lo potencia."
								}
							]
						}
					]
				},
				"taxonomies": {
					"category": ["educacion"]
				}
			},
			{
				"id": "post-desafio-en",
				"slug": "the-challenge-of-evidence-based-teaching",
				"status": "published",
				"locale": "en",
				"translationOf": "post-desafio-es",
				"data": {
					"title": "The challenge of evidence-based teaching",
					"excerpt": "Learning can also be read. Today's educators must not only teach well but interpret what data reveals about how students learn.",
					"featured_image": {
						"$media": {
							"url": "https://cdn.prod.website-files.com/687f946a33c5b5ae33cf179d/688383c8f2a197187d77da8f_ensen%CC%83anzapersonalizada.png",
							"alt": "The challenge of evidence-based teaching",
							"filename": "blog-post-1.png"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "In today's world, information is a strategic tool. Education needs evidence, critical reading, and professionals who can analyze learning as a visible, measurable process."
								}
							]
						},
						{
							"_type": "block",
							"style": "h2",
							"children": [{ "_type": "span", "text": "What is Learning Analytics?" }]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Learning Analytics is the process of collecting, analyzing, and interpreting data generated by students to understand and optimize learning. It does not replace educators—it empowers them."
								}
							]
						}
					]
				},
				"taxonomies": {
					"category": ["education"]
				}
			},
			{
				"id": "post-unab-es",
				"slug": "tutor-virtual-basado-en-ia-de-la-unab-una-nueva-experiencia-educativa",
				"status": "published",
				"locale": "es",
				"data": {
					"title": "Tutor virtual basado en IA de la UNAB: Una nueva experiencia educativa",
					"excerpt": "La Universidad Nacional Andrés Bello implementó un tutor virtual basado en inteligencia artificial en Canvas.",
					"featured_image": {
						"$media": {
							"url": "https://cdn.prod.website-files.com/687f946a33c5b5ae33cf179d/688045c6d87449edf915c3c9_blog-2.webp",
							"alt": "Tutor virtual UNAB",
							"filename": "blog-post-2.webp"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "La UNAB en Chile dio un audaz paso hacia el futuro de la educación implementando un tutor virtual basado en IA para Canvas, desarrollado con AWS Bedrock y AWS Lambda para escalar según la demanda académica."
								}
							]
						}
					]
				},
				"taxonomies": {
					"category": ["caso-de-exito"]
				}
			},
			{
				"id": "post-unab-en",
				"slug": "unab-ai-virtual-tutor-a-new-educational-experience",
				"status": "published",
				"locale": "en",
				"translationOf": "post-unab-es",
				"data": {
					"title": "UNAB's AI-based virtual tutor: A new educational experience",
					"excerpt": "Universidad Andrés Bello implemented an AI virtual tutor on Canvas.",
					"featured_image": {
						"$media": {
							"url": "https://cdn.prod.website-files.com/687f946a33c5b5ae33cf179d/688045c6d87449edf915c3c9_blog-2.webp",
							"alt": "UNAB virtual tutor",
							"filename": "blog-post-2.webp"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "UNAB in Chile took a bold step toward the future of education by implementing an AI virtual tutor for Canvas, built with AWS Bedrock and AWS Lambda to scale with academic demand."
								}
							]
						}
					]
				},
				"taxonomies": {
					"category": ["case-study"]
				}
			},
			{
				"id": "post-entorno-es",
				"slug": "como-se-construye-un-buen-entorno-de-aprendizaje-92z4e",
				"status": "published",
				"locale": "es",
				"data": {
					"title": "¿Cómo se construye un buen entorno de aprendizaje?",
					"excerpt": "La ciencia del aprendizaje y la tecnología permiten escalar entornos inclusivos, flexibles y basados en evidencia.",
					"featured_image": {
						"$media": {
							"url": "https://cdn.prod.website-files.com/687f946a33c5b5ae33cf179d/6883851749749d9c2280e109_studentexperience.png",
							"alt": "Entorno de aprendizaje",
							"filename": "blog-post-3.png"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Un entorno de aprendizaje ideal combina pedagogía basada en evidencia con tecnología significativa. Los tutores virtuales con IA encarnan inclusión, flexibilidad, seguridad y uso estratégico de datos."
								}
							]
						}
					]
				},
				"taxonomies": {
					"category": ["educacion"]
				}
			},
			{
				"id": "post-entorno-en",
				"slug": "how-to-build-a-strong-learning-environment",
				"status": "published",
				"locale": "en",
				"translationOf": "post-entorno-es",
				"data": {
					"title": "How to build a strong learning environment",
					"excerpt": "Learning science and technology make it possible to scale inclusive, flexible, evidence-based environments.",
					"featured_image": {
						"$media": {
							"url": "https://cdn.prod.website-files.com/687f946a33c5b5ae33cf179d/6883851749749d9c2280e109_studentexperience.png",
							"alt": "Learning environment",
							"filename": "blog-post-3.png"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "An ideal learning environment combines evidence-based pedagogy with meaningful technology. AI virtual tutors embody inclusion, flexibility, safety, and strategic use of data."
								}
							]
						}
					]
				},
				"taxonomies": {
					"category": ["education"]
				}
			}
